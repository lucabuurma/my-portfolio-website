---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { title } = Astro.props;
---

<!doctype html>
<html
  data-wf-page="689c9d9dd3a17615f1ee5fbb"
  data-wf-site="689c9d9cd3a17615f1ee5e65"
  lang="en"
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Luca Büürma</title>
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <link
      rel="stylesheet"
      href="https://cdn.prod.website-files.com/689c9d9cd3a17615f1ee5e65/css/lucas-personal-brand-go-live.webflow.shared.8b224947f.min.css"
    />
    <link rel="stylesheet" href="/css/normalize.css" />
    <link rel="stylesheet" href="/css/webflow.css" />
    <link
      rel="stylesheet"
      href="/css/lucas-personal-brand-go-live.webflow.css"
    />
    <script is:inline>
      !(function (o, c) {
        var n = c.documentElement,
          t = " w-mod-";
        ((n.className += t + "js"),
          ("ontouchstart" in o ||
            (o.DocumentTouch && c instanceof DocumentTouch)) &&
            (n.className += t + "touch"));
      })(window, document);
    </script>
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
    <script
      is:inline
      src="https://d3e54v103j8qbb.cloudfront.net/js/jquery-3.5.1.min.dc5e7f18c8.js?site=689c9d9cd3a17615f1ee5e65"
      integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0="
      crossorigin="anonymous"></script>
    <script is:inline src="/js/webflow.js"></script>
  </body>
</html>
